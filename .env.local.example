# MongoDB connection string
# Príklad: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/orange-vypisy
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/orange-vypisy

# JWT secret — vygenerujte napr.: openssl rand -base64 32
JWT_SECRET=zmente-toto-na-bezpecny-nahodny-retazec

# Ecomail.cz transakčné emaily
# API kľúč nájdete v Ecomail → Nastavenia → API
ECOMAIL_API_KEY=vas-ecomail-api-kluc

# Odosielateľ emailov
# FROM_EMAIL musí byť z domény overenej v Ecomail (Nastavenia → Odosielacie domény)
# Táto adresa zároveň určuje primárneho správcu vytvoreného pri prvom štarte
FROM_EMAIL=noreply@mail.domena.sk
FROM_NAME=Orange Fakturácia

# Adresa pre odpovede (voliteľné) — ak sa líši od FROM_EMAIL
# Napríklad skutočná schránka, keď FROM_EMAIL je no-reply adresa na overenej subdoméne
REPLY_TO_EMAIL=orange@domena.sk

# Verejná URL aplikácie (bez lomítka na konci)
APP_URL=https://orange.domena.sk

# Názov organizácie zobrazovaný v UI (badge, footer)
PUBLIC_ORG_NAME=Názov organizácie
